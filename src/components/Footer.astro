---
const today = new Date();
---

<footer class="mt-16 border-t border-border bg-surface">
	<div class="mx-auto flex max-w-4xl items-center justify-between px-6 py-10 md:px-8">
		<div class="flex flex-col gap-1">
			<span class="font-serif text-base font-bold text-ink">前端周刊</span>
			<p class="m-0 text-sm text-ink-muted">每周精选前端技术文章、工具与版本发布</p>
		</div>
		<div class="flex gap-2">
			<a href="https://x.com/shfshanyue" target="_blank"
				class="flex h-9 w-9 items-center justify-center rounded-md text-ink-muted transition-all duration-200 ease-out hover:bg-border-light hover:text-ink cursor-pointer">
				<span class="sr-only">在 X 上关注山月</span>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18"
					><path fill="currentColor" d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg>
			</a>
			<a href="https://github.com/shfshanyue/weekly" target="_blank"
				class="flex h-9 w-9 items-center justify-center rounded-md text-ink-muted transition-all duration-200 ease-out hover:bg-border-light hover:text-ink cursor-pointer">
				<span class="sr-only">前往 GitHub 仓库</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="18" height="18"
					><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path></svg>
			</a>
			<a href="/rss.xml" target="_blank"
				class="flex h-9 w-9 items-center justify-center rounded-md text-ink-muted transition-all duration-200 ease-out hover:bg-border-light hover:text-ink cursor-pointer">
				<span class="sr-only">RSS 订阅</span>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18"
					><path fill="currentColor" d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z"></path></svg>
			</a>
		</div>
	</div>
	<div class="mx-auto max-w-4xl px-6 pb-8 text-xs text-ink-muted md:px-8">
		&copy; {today.getFullYear()} 前端周刊 · All rights reserved.
	</div>
</footer>
